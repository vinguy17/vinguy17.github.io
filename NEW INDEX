<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Vivian Nguyen — Portfolio</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --text-primary: #1a1a18;
    --text-secondary: #888780;
    --text-muted: #aaa;
    --border: rgba(0,0,0,0.08);
    --bg: #fff;
    --bg-light: #f5f5f3;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
    background: var(--bg);
    color: var(--text-primary);
    line-height: 1.6;
    font-size: 16px;
    max-width: 960px;
    margin: 0 auto;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 0.5px solid var(--border);
    z-index: 100;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 54px;
  }
  .nav-logo {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
  }
  .nav-links a:hover,
  .nav-links a.active { color: var(--text-primary); }

  /* TABS */
  .tab-bar {
    display: flex;
    border-bottom: 0.5px solid var(--border);
    padding: 0 2rem;
  }
  .tab-btn {
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 12px 0;
    margin-right: 2rem;
    border: none;
    border-bottom: 1.5px solid transparent;
    background: none;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    margin-bottom: -0.5px;
  }
  .tab-btn:hover { color: var(--text-primary); }
  .tab-btn.active {
    color: var(--text-primary);
    border-bottom-color: var(--text-primary);
    font-weight: 500;
  }

  /* PANELS */
  .panel { display: none; }
  .panel.active { display: block; }

  /* HERO */
  .hero {
    padding: 3rem 2rem 2.5rem;
    border-bottom: 0.5px solid var(--border);
  }
  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.25;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }
  .hero p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
  }

  /* WORK GRID */
  .work-section { padding: 2rem; }
  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .wcard {
    text-decoration: none;
    color: inherit;
    display: block;
    cursor: pointer;
  }
  .wcard:hover .wcard-title { color: var(--text-secondary); }
  .wcard-thumb {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-radius: 6px;
    background: var(--bg-light);
    margin-bottom: 10px;
    position: relative;
  }
  .wcard-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .wcard:hover .wcard-thumb img { transform: scale(1.02); }
  .dark-thumb {
    width: 100%;
    height: 100%;
    background: #1a1a18;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .light-thumb {
    width: 100%;
    height: 100%;
    background: var(--bg-light);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .play-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .play-tri {
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 10px solid rgba(255,255,255,0.65);
    margin-left: 2px;
  }
  .wcard-type {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.03em;
    margin-bottom: 4px;
  }
  .wcard-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.4;
    letter-spacing: -0.01em;
    transition: color 0.2s;
  }

  /* ABOUT */
  .about-section {
    padding: 2.5rem 2rem;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 3rem;
    align-items: start;
  }
  .about-photo-wrap { position: relative; }
  .about-photo {
    width: 100%;
    aspect-ratio: 3/4;
    border-radius: 6px;
    background: var(--bg-light);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
  .photo-credit {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 8px;
    text-align: center;
  }
  .about-content {}
  .about-name {
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .about-role {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 1.75rem;
    letter-spacing: 0.01em;
  }
  .about-bio {
    font-size: 14px;
    color: #444;
    line-height: 1.85;
    margin-bottom: 2rem;
  }
  .about-bio p { margin-bottom: 1rem; }
  .about-bio p:last-child { margin-bottom: 0; }
  .about-details {
    border-top: 0.5px solid var(--border);
    padding-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .detail-label {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 4px;
  }
  .detail-value {
    font-size: 13px;
    color: var(--text-primary);
    line-height: 1.55;
  }

  /* CONTACT */
  .contact-section {
    border-top: 0.5px solid var(--border);
    padding-top: 1.5rem;
  }
  .contact-label {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .contact-links { display: flex; flex-direction: column; gap: 8px; }
  .contact-link {
    font-size: 13px;
    color: var(--text-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.2s;
  }
  .contact-link:hover { color: var(--text-secondary); }
  .contact-link-label {
    font-size: 11px;
    color: var(--text-muted);
    width: 60px;
    flex-shrink: 0;
  }

  /* FOOTER */
  footer {
    border-top: 0.5px solid var(--border);
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 2rem;
  }
  footer p {
    font-size: 11px;
    color: var(--text-muted);
  }

  /* PLACEHOLDER SVG */
  .doc-icon { opacity: 0.25; }

  @media (max-width: 680px) {
    .work-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .about-section { grid-template-columns: 1fr; }
    .about-photo { aspect-ratio: 1/1; }
    nav { padding: 0 1rem; }
    .hero, .work-section { padding-left: 1rem; padding-right: 1rem; }
    .tab-bar { padding: 0 1rem; }
  }

  @media (max-width: 420px) {
    .work-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
