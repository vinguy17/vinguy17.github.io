<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Your Name — Portfolio</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --teal-50: #E1F5EE;
    --teal-100: #9FE1CB;
    --teal-400: #1D9E75;
    --teal-600: #0F6E56;
    --teal-800: #085041;
    --teal-900: #04342C;
    --amber-50: #FAEEDA;
    --amber-100: #FAC775;
    --amber-400: #BA7517;
    --coral-50: #FAECE7;
    --coral-100: #F5C4B3;
    --gray-50: #F1EFE8;
    --gray-100: #D3D1C7;
    --gray-400: #888780;
    --text-primary: #1a1a18;
    --text-secondary: #5F5E5A;
    --text-muted: #888780;
    --border: rgba(0,0,0,0.09);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Georgia', serif;
    background: #fff;
    color: var(--text-primary);
    line-height: 1.7;
    font-size: 16px;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 0.5px solid var(--border);
    z-index: 100;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .nav-logo {
    font-family: 'Georgia', serif;
    font-size: 17px;
    font-weight: normal;
    letter-spacing: 0.01em;
    color: var(--text-primary);
    text-decoration: none;
  }
  .nav-logo span { color: var(--teal-600); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--teal-600); }

  /* HERO */
  .hero {
    padding: 5rem 2rem 4rem;
    max-width: 860px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: center;
  }
  .hero-text h1 {
    font-family: 'Georgia', serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: normal;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }
  .hero-text h1 em {
    font-style: italic;
    color: var(--teal-600);
  }
  .hero-text p {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 2rem;
  }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    background: var(--teal-600);
    color: #fff;
    border: none;
    padding: 10px 22px;
    border-radius: 4px;
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 0.04em;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--teal-800); }
  .btn-secondary {
    background: transparent;
    color: var(--text-primary);
    border: 0.5px solid var(--gray-400);
    padding: 10px 22px;
    border-radius: 4px;
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 0.04em;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    display: inline-block;
  }
  .btn-secondary:hover { border-color: var(--teal-600); color: var(--teal-600); }

  /* AVATAR */
  .hero-avatar { position: relative; }
  .avatar-frame {
    width: 240px;
    height: 280px;
    border-radius: 6px;
    background: var(--teal-50);
    border: 0.5px solid var(--teal-100);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .avatar-initials {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--teal-400);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: -apple-system, sans-serif;
    font-size: 22px;
    font-weight: 500;
    color: #fff;
    letter-spacing: 0.05em;
  }
  .avatar-label {
    font-family: -apple-system, sans-serif;
    font-size: 11px;
    color: var(--teal-600);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .accent-bar {
    position: absolute;
    bottom: -8px;
    right: -8px;
    width: 60px;
    height: 60px;
    border-radius: 4px;
    background: var(--amber-50);
    border: 0.5px solid var(--amber-100);
    z-index: -1;
  }

  /* SECTIONS */
  section {
    padding: 4rem 2rem;
    max-width: 860px;
    margin: 0 auto;
  }
  .section-label {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal-600);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  .section-title {
    font-family: 'Georgia', serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: normal;
    color: var(--text-primary);
    margin-bottom: 2.5rem;
    line-height: 1.3;
  }
  .divider {
    width: 100%;
    height: 0.5px;
    background: var(--border);
    max-width: 860px;
    margin: 0 auto;
  }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .about-bio p {
    font-family: 'Georgia', serif;
    font-size: 16px;
    color: var(--text-primary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .about-bio p:last-child { margin-bottom: 0; }
  .about-details { display: flex; flex-direction: column; gap: 20px; }
  .detail-item {
    border-left: 2px solid var(--teal-100);
    padding-left: 16px;
  }
  .detail-label {
    font-family: -apple-system, sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-600);
    margin-bottom: 4px;
    font-weight: 500;
  }
  .detail-value {
    font-family: -apple-system, sans-serif;
    font-size: 14px;
    color: var(--text-primary);
    line-height: 1.5;
  }

  /* FILTERS */
  .work-filter {
    display: flex;
    gap: 8px;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .filter-btn {
    font-family: -apple-system, sans-serif;
    font-size: 12px;
    letter-spacing: 0.05em;
    padding: 6px 14px;
    border-radius: 20px;
    border: 0.5px solid var(--gray-100);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn:hover { border-color: var(--teal-400); color: var(--teal-600); }
  .filter-btn.active {
    background: var(--teal-600);
    color: #fff;
    border-color: var(--teal-600);
  }

  /* WORK CARDS */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }
  .work-card {
    border: 0.5px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
    background: #fff;
  }
  .work-card:hover { border-color: var(--teal-400); transform: translateY(-2px); }
  .card-thumb {
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .thumb-writing { background: var(--teal-50); }
  .thumb-video { background: #1a1a18; }
  .thumb-web { background: var(--amber-50); }
  .card-type-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    font-family: -apple-system, sans-serif;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 3px;
  }
  .badge-writing { background: var(--teal-100); color: var(--teal-800); }
  .badge-video { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9); }
  .badge-web { background: var(--amber-100); color: var(--amber-400); }
  .card-body { padding: 16px; }
  .card-title {
    font-family: 'Georgia', serif;
    font-size: 15px;
    font-weight: normal;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 6px;
  }
  .card-desc {
    font-family: -apple-system, sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .card-tag {
    font-family: -apple-system, sans-serif;
    font-size: 11px;
    color: var(--teal-600);
    letter-spacing: 0.04em;
  }
  .ext-icon { font-size: 13px; color: var(--text-muted); }

  /* FEATURED VIDEO ROW */
  .featured-row {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .featured-card {
    border: 0.5px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color 0.2s;
    background: #fff;
  }
  .featured-card:hover { border-color: var(--teal-400); }
  .featured-thumb {
    height: 180px;
    background: #1a1a18;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .play-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    border: 1.5px solid rgba(255,255,255,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .play-triangle {
    width: 0;
    height: 0;
    border-top: 8px solid transparent;
    border-bottom: 8px solid transparent;
    border-left: 14px solid rgba(255,255,255,0.8);
    margin-left: 3px;
  }
  .featured-body { padding: 20px; }
  .featured-label {
    font-family: -apple-system, sans-serif;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal-600);
    font-weight: 500;
    margin-bottom: 8px;
  }
  .featured-title {
    font-family: 'Georgia', serif;
    font-size: 18px;
    font-weight: normal;
    line-height: 1.4;
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .featured-desc {
    font-family: -apple-system, sans-serif;
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* CONTACT */
  .contact-section {
    padding: 4rem 2rem 5rem;
    max-width: 860px;
    margin: 0 auto;
  }
  .contact-inner {
    background: var(--teal-50);
    border: 0.5px solid var(--teal-100);
    border-radius: 12px;
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .contact-text h2 {
    font-family: 'Georgia', serif;
    font-size: 1.8rem;
    font-weight: normal;
    color: var(--teal-900);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .contact-text p {
    font-family: -apple-system, sans-serif;
    font-size: 14px;
    color: var(--teal-600);
    line-height: 1.7;
  }
  .contact-links { display: flex; flex-direction: column; gap: 12px; }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: #fff;
    border: 0.5px solid var(--teal-100);
    border-radius: 6px;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .contact-link:hover { border-color: var(--teal-400); }
  .contact-link-icon {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: var(--teal-100);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    color: var(--teal-600);
    font-weight: 600;
  }
  .contact-link-label {
    font-family: -apple-system, sans-serif;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  .contact-link-value {
    font-family: -apple-system, sans-serif;
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* FOOTER */
  footer {
    border-top: 0.5px solid var(--border);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 860px;
    margin: 0 auto;
  }
  footer p {
    font-family: -apple-system, sans-serif;
    font-size: 12px;
    color: var(--text-muted);
  }
  .footer-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal-400);
    display: inline-block;
    margin-right: 6px;
  }

  @media (max-width: 680px) {
    .hero { grid-template-columns: 1fr; gap: 2rem; }
    .hero-avatar { display: none; }
    .about-grid { grid-template-columns: 1fr; }
    .featured-row { grid-template-columns: 1fr; }
    .contact-inner { grid-template-columns: 1fr; }
    .nav-links { display: none; }
  }
</style>
</head>
